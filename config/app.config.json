  "auth": {
    "enabled": true,
    "methods": ["email", "demo"],
    "fields": [
      { "name": "email", "label": { "en": "Email", "hi": "ईमेल" }, "type": "email", "required": true },
      { "name": "password", "label": { "en": "Password", "hi": "पासवर्ड" }, "type": "password", "required": true }
    ]
  },
  "entities": [
    {
      "name": "products",
      "label": { "en": "Products", "hi": "उत्पाद" },
      "fields": [
        { "name": "name", "type": "text", "label": { "en": "Product Name", "hi": "उत्पाद नाम" } },
        { "name": "price", "type": "number", "label": { "en": "Price", "hi": "कीमत" } },
        { "name": "category", "type": "text", "label": { "en": "Category", "hi": "श्रेणी" } },
        { "name": "brand", "type": "text", "label": { "en": "Brand", "hi": "ब्रांड" } }
      ]
    },
    {
      "name": "orders",
      "label": { "en": "Orders", "hi": "ऑर्डर" },
      "fields": [
        { "name": "orderId", "type": "text", "label": { "en": "Order ID", "hi": "ऑर्डर ID" } },
        { "name": "amount", "type": "number", "label": { "en": "Amount", "hi": "राशि" } }
      ]
    },
    {
      "name": "customers",
      "label": { "en": "Customers", "hi": "ग्राहक" },
      "userScoped": true,
      "fields": [
        { "name": "name", "label": { "en": "Name", "hi": "नाम" }, "type": "text", "required": true },
        { "name": "email", "label": { "en": "Email", "hi": "ईमेल" }, "type": "email" },
        { "name": "company", "label": { "en": "Company", "hi": "कंपनी" }, "type": "text" },
        { "name": "status", "label": { "en": "Status", "hi": "स्थिति" }, "type": "select", "default": "Lead", "options": ["Lead", "Active", "Churned"] },
        { "name": "notes", "label": { "en": "Notes", "hi": "नोट्स" }, "type": "textarea" }
      ]
    },
    {
      "name": "deals",
      "label": { "en": "Deals", "hi": "डील" },
      "userScoped": true,
      "fields": [
        { "name": "title", "label": { "en": "Title", "hi": "शीर्षक" }, "type": "text", "required": true },
        { "name": "value", "label": { "en": "Value", "hi": "मूल्य" }, "type": "number", "default": 0 },
        { "name": "stage", "label": { "en": "Stage", "hi": "स्टेज" }, "type": "select", "default": "Pipeline", "options": ["Pipeline", "Negotiation", "Won", "Lost"] },
        { "name": "closeDate", "label": { "en": "Close Date", "hi": "समाप्ति तारीख" }, "type": "date" }
      ]
    }
  ],
  "ui": {
    "navigation": [
      { "labelKey": "nav.dashboard", "view": "dashboard" },
      { "labelKey": "nav.customers", "entity": "customers" },
      { "labelKey": "nav.deals", "entity": "deals" },
      { "labelKey": "nav.products", "entity": "products" },
      { "labelKey": "nav.orders", "entity": "orders" },
      { "labelKey": "nav.notifications", "view": "notifications" }
    ],
    "views": [
      {
        "type": "dashboard",
        "title": { "en": "Overview", "hi": "ओवरव्यू" },
        "widgets": [
          { "type": "metric", "entity": "customers", "label": { "en": "Customers", "hi": "ग्राहक" } },
          { "type": "metric", "entity": "deals", "label": { "en": "Deals", "hi": "डील" } },
          { "type": "table", "entity": "deals", "label": { "en": "Recent deals", "hi": "हाल की डील" }, "limit": 5 }
        ]
      }
    ]
  },
  "notifications": {
    "enabled": true,
    "rules": [
      { "event": "customers.created", "message": "New customer added", "email": true },
      { "event": "deals.created", "message": "New deal created", "email": true },
      { "event": "csv.imported", "message": "CSV import completed", "email": false }
    ]
  }
}
