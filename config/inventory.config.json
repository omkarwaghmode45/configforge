  "auth": {
    "enabled": true,
    "methods": ["email"],
    "fields": [
      { "name": "email", "label": "Email", "type": "email", "required": true },
      { "name": "password", "label": "Password", "type": "password", "required": true }
    ]
  },
  "entities": [
    {
      "key": "inventory",
      "name": { "en": "Inventory", "hi": "इन्वेंटरी" },
      "fields": [
        { "name": "itemName", "type": "text", "label": { "en": "Item Name", "hi": "आइटम नाम" }, "required": true },
        { "name": "sku", "type": "text", "label": { "en": "SKU", "hi": "SKU" } },
        { "name": "quantity", "type": "number", "label": { "en": "Quantity", "hi": "मात्रा" }, "default": 0 },
        { "name": "location", "type": "text", "label": { "en": "Location", "hi": "स्थान" } },
        { "name": "category", "type": "select", "label": { "en": "Category", "hi": "श्रेणी" }, "default": "General", "options": [{ "value": "General", "label": { "en": "General", "hi": "सामान्य" } }, { "value": "Hardware", "label": { "en": "Hardware", "hi": "हार्डवेयर" } }, { "value": "Software", "label": { "en": "Software", "hi": "सॉफ्टवेयर" } }, { "value": "Supplies", "label": { "en": "Supplies", "hi": "आपूर्ति" } }] }
      ]
    }
  ],
  "ui": {
    "navigation": [
      { "labelKey": "nav.entities", "view": "dashboard" },
      { "labelKey": "nav.notifications", "view": "notifications" }
    ],
    "views": [
      {
        "type": "dashboard",
        "title": { "en": "Entities", "hi": "Entities" },
        "widgets": [
          { "type": "metric", "entity": "inventory", "label": { "en": "Inventory", "hi": "इन्वेंटरी" } },
          { "type": "table", "entity": "inventory", "label": { "en": "Recent records", "hi": "हाल के रिकॉर्ड" }, "limit": 5 }
        ]
      }
    ]
  },
  "notifications": {
    "enabled": true,
    "rules": [
      { "event": "inventory.created", "message": { "en": "New inventory item added", "hi": "नया इन्वेंटरी आइटम जोड़ा गया" }, "email": true },
      { "event": "csv.imported", "message": { "en": "CSV import completed", "hi": "CSV आयात पूरा हुआ" }, "email": false }
    ]
  }
}
